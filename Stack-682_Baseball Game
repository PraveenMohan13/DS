class Solution {
    public int calPoints(String[] s) {
        Stack<Integer> st=new Stack<>();
        for(int i=0;i<s.length;i++)
        {
            if(s[i].equals("+"))
            {
                int a=st.pop();
                int b=st.peek();
                int c=a+b;
                st.push(a);
                st.push(c);
            }
            else if(s[i].equals("D"))
            {
                st.push(st.peek()*2);
            }
            else if(s[i].equals("C"))
                st.pop();
            else
                st.push(Integer.parseInt(s[i]));
        }
        int sum=0;
        while(!st.isEmpty())
        {
            sum += st.pop();
        }
    return sum;
    }
}
