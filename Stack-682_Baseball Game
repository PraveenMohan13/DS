class Solution {
    public int calPoints(String[] s) {
        Stack<Integer> st=new Stack<>();

        for(int i=0;i<s.length;i++)
        {
            if( s[i].equals("C") && !st.isEmpty() )
            {
                st.pop();
            }
            else if(s[i].equals("D") && !st.isEmpty())
            {
                st.push(st.peek()*2);
            }
            else if( s[i].equals("+") && !st.isEmpty() )
            {
                int a=st.pop();
                int b=0;
                if(!st.isEmpty())
                    b=st.peek();
                st.push(a);
                st.push(b+a);
            }
            else
                st.push(Integer.parseInt(s[i]));


        }
        int sum=0;
        while(!st.isEmpty())
        {            
            sum+=st.pop();
        }

        return sum;
    }
}
